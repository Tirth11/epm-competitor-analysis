{
  "name": "epm-competitor-analysis",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "dev:api": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:prod": "npm run build && npm run build:server",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "serve:public": "npx serve dist -l 8080",
    "start": "tsx server/index.ts",
    "start:prod": "node dist-server/server/index.js",
    "daemon:start": "npx pm2 start ecosystem.config.cjs",
    "daemon:restart": "npx pm2 restart epm-competitor-analysis",
    "daemon:stop": "npx pm2 stop epm-competitor-analysis",
    "daemon:logs": "npx pm2 logs epm-competitor-analysis",
    "daemon:save": "npx pm2 save"
  },
  "dependencies": {
    "axios": "^1.15.1",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "pm2": "^6.0.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  }
}
